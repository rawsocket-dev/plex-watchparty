# plex-watchparty configuration. Copy to .env and fill in.
# docker compose injects every line here into the container (env_file),
# so this file is the single source of truth for configuration.

# --- Plex (required) ---
# Your Plex server URL (token stays server-side, never sent to clients).
# From a container, host.docker.internal reaches the Docker host.
PLEX_BASE_URL=http://192.168.1.10:32400
PLEX_TOKEN=xxxxxxxxxxxx

# --- Google OAuth (required) — one client for sign-in + roles ---
# See README "Google Cloud setup" for how to create these.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
GOOGLE_REDIRECT_URL=https://watch.example.com/oauth/callback

# --- Access control (comma-separated emails, lowercased server-side) ---
# ALLOWED_EMAILS — who may sign in & watch (required).
# HOST_EMAILS    — subset who can pick / play / pause / seek (empty = everyone allowed can drive).
# ADMIN_EMAILS   — subset who can open /admin (empty = no one).
ALLOWED_EMAILS=you@example.com,friend@example.com
HOST_EMAILS=you@example.com
ADMIN_EMAILS=you@example.com

# --- Discord webhook (optional) ---
# When set, posts a rich embed when a movie starts and ends. Unset = off.
DISCORD_WEBHOOK_URL=
# Public origin for the poster-image links in Discord embeds (e.g.
# https://watch.example.com). Enabling the webhook serves an unauthenticated,
# read-only /poster/<ratingKey>.jpg route (Plex token stripped) so Discord
# can render the poster. Defaults to the origin of GOOGLE_REDIRECT_URL.
# PUBLIC_BASE_URL=

# --- Tuning (optional; sensible built-in defaults) ---
# Plex transcoder target bitrate in kbps (default 12000).
# PLEX_TRANSCODE_BITRATE_KBPS=12000
# HLS segment cache disk cap in GB (default 20).
# CACHE_MAX_GB=20
# Listen address (default :8080; keep in sync with the compose port mapping).
# LISTEN_ADDR=:8080
